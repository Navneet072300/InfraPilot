# ── AI Provider ───────────────────────────────────────────────────────────────
# Ollama takes priority when OLLAMA_URL is set. Leave blank to skip.
OLLAMA_URL=
OLLAMA_MODEL=gemma4:31b

# Groq fallback — used when Ollama is unavailable (groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic fallback — used when both Ollama and Groq are unavailable
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# If set, PostgreSQL is used; otherwise a local JSON file is used
DATABASE_URL=postgresql://infrapilot:infrapilot@localhost:5432/infrapilot

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_FILE=config/platforms.json

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional: PAT for repository operations (can also be set via onboarding UI)
GITHUB_PAT=ghp_...

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# ── Email OTP ─────────────────────────────────────────────────────────────────
# Resend (resend.com) — for OTP emails
RESEND_API_KEY=

# ── WhatsApp OTP ──────────────────────────────────────────────────────────────
# Twilio (twilio.com/whatsapp) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
